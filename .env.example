# Executive AI Assistant — Environment Variables
# Copy this file to .env and fill in real values

# ── Core ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal Telegram chat ID — send /start to bot, find ID in logs
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# LLM Provider: groq (default), ollama, or anthropic
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key_here
# Only needed if LLM_PROVIDER=anthropic:
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama (local, private) — uncomment to switch:
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Google (Gmail + Calendar) ──────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Primary account (jynpriority@gmail.com):
GOOGLE_REFRESH_TOKEN=your_primary_refresh_token_here
# Secondary account (jngai5.3@gmail.com) — optional:
GOOGLE_REFRESH_TOKEN_JNGAI53=your_secondary_refresh_token_here

# ── Integrations ───────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here
NOTION_TOKEN=your_notion_integration_token_here

# ── Google Sheets (CC/Bank Bonus Logging) ─────────────────────
GOOGLE_SHEETS_CC_WEBHOOK=your_google_sheets_webhook_url_here
GOOGLE_SHEETS_BANK_WEBHOOK=your_google_sheets_webhook_url_here

# ── Paperstac (Mortgage Notes Scraper) ────────────────────────
PAPERSTAC_EMAIL=your_paperstac_email_here
PAPERSTAC_PASSWORD=your_paperstac_password_here

# ── Origin Financial ──────────────────────────────────────────
ORIGIN_EMAIL=your_origin_email_here
ORIGIN_PASSWORD=your_origin_password_here

# ── Notion Events (NYC Events Tracker) ────────────────────────
NOTION_EVENTS_DB_ID=          # from scripts/notion_events_bootstrap.py
JUSTIN_PHONE=                  # optional: your phone for Playwright autofill
JUSTIN_EMAIL=jngai5.3@gmail.com  # used by Playwright registration
