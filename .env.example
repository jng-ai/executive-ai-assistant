# Copy this to .env and fill in your values

# === LLM PROVIDER (pick one) ===
LLM_PROVIDER=groq                          # groq (free) | ollama (local free) | anthropic (paid)
LLM_MODEL=llama-3.3-70b-versatile         # auto-set per provider, override here if needed

# === GROQ (free tier — recommended) ===
# Get key at: console.groq.com (free, no credit card)
GROQ_API_KEY=your_groq_key_here

# === OLLAMA (local, completely free — alternative) ===
# Install: brew install ollama && ollama pull llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1

# === ANTHROPIC (paid — only if you want Claude) ===
# ANTHROPIC_API_KEY=your_anthropic_key_here

# === REQUIRED ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === OPTIONAL: Web Search (free tier) ===
# Get key at: brave.com/search/api — 2000 free searches/month
BRAVE_API_KEY=your_brave_search_key_here

# === OPTIONAL: Database (Supabase free tier) ===
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# === OPTIONAL: Productivity ===
NOTION_API_KEY=your_notion_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# === OPTIONAL: Google (for calendar + gmail) ===
GOOGLE_CREDENTIALS_FILE=config/google_credentials.json
