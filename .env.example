# ─────────────────────────────────────────────────────────────────────────────
# Executive AI Assistant — Environment Variables Template
# Copy this file to .env and fill in real values. .env is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────────────────────────
# groq    = free cloud API, fast (default)
# ollama  = 100% local/private, no data leaves your machine (see setup below)
# anthropic = paid, most capable
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Ollama (local, private) — uncomment to switch:
# brew install ollama && ollama pull llama3.2
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Groq — free LLM API ───────────────────────────────────────────────────────
# console.groq.com — free, no credit card required
GROQ_API_KEY=

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your personal chat ID — send /start to bot, find ID in logs
TELEGRAM_CHAT_ID=

# ── Tavily — web search API ───────────────────────────────────────────────────
# app.tavily.com — 1,000 free searches/month
TAVILY_API_KEY=

# ── Notion ────────────────────────────────────────────────────────────────────
# notion.so/my-integrations — create integration, share page with it
NOTION_API_KEY=
# Page ID from the Notion URL: notion.so/Page-Name-[THIS_32_CHAR_ID]
NOTION_PARENT_PAGE_ID=

# ── Google Sheets Webhooks (Apps Script) ─────────────────────────────────────
# Paste the Web App deployment URLs from each sheet's Apps Script
GOOGLE_SHEETS_CC_WEBHOOK=
GOOGLE_SHEETS_BANK_WEBHOOK=

# ── Google OAuth2 — Calendar + Gmail ─────────────────────────────────────────
# Setup:
#   1. console.cloud.google.com → new project → enable Calendar API + Gmail API
#   2. APIs & Services → Credentials → OAuth 2.0 Client ID → Desktop app
#   3. Download client_secret_*.json to ~/Downloads
#   4. Run: python scripts/google_auth.py  (one-time browser login)
#   5. GOOGLE_REFRESH_TOKEN is auto-written below after auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Anthropic (optional — only if LLM_PROVIDER=anthropic) ────────────────────
# ANTHROPIC_API_KEY=
